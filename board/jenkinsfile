pipeline {
    agent any

    tools {
        maven 'Maven'
        jdk 'JDK17'
    }

    environment {
        DOCKER_IMAGE = "cloudshield-app"
        CONTAINER_NAME = "cloudshield-container"
    }

    stages {

        stage('Clone Code') {
            steps {
                git branch: 'main', url: 'https://github.com/Balarajuvelpula/CloudShield_DevSecOps_Hackathon_2026.git'
            }
        }

        stage('Build Application') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Run Unit Tests') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Code Quality - SonarQube') {
            steps {
                script {
                    withSonarQubeEnv('SonarQube') {
                        sh 'mvn sonar:sonar'
                    }
                }
            }
        }

        stage('Filesystem Security Scan (Trivy)') {
            steps {
                sh 'trivy fs . || true'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE .'
            }
        }

        stage('Docker Image Scan') {
            steps {
                sh 'trivy image $DOCKER_IMAGE || true'
            }
        }

        stage('Deploy Container') {
            steps {
                sh '''
                docker rm -f $CONTAINER_NAME || true
                docker run -d -p 8081:8080 --name $CONTAINER_NAME $DOCKER_IMAGE
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Application Successfully Deployed!'
        }
        failure {
            echo '❌ Pipeline Failed!'
        }
        always {
            echo 'Pipeline Execution Completed'
        }
    }
}
